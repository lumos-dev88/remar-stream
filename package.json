{
  "name": "remar-stream",
  "version": "0.1.2",
  "description": "Streaming Markdown renderer for AI chat — supports KaTeX math, Mermaid diagrams, code highlighting, and plugin extension",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/index.css"
  },
  "sideEffects": [
    "dist/*.css"
  ],
  "files": [
    "dist",
    "README.md",
    "README.zh-CN.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lumos-dev88/remar-stream.git"
  },
  "homepage": "https://github.com/lumos-dev88/remar-stream#readme",
  "bugs": {
    "url": "https://github.com/lumos-dev88/remar-stream/issues"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "lint": "eslint src"
  },
  "dependencies": {
    "katex": "^0.16.0",
    "lucide-react": "^0.500.0",
    "marked": "^17.0.0",
    "mermaid": "^11.14.0",
    "prismjs": "^1.30.0",
    "react-markdown": "^10.0.0",
    "rehype-katex": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math-extended": "^6.1.0",
    "remend": "^1.3.0",
    "unist-util-visit": "^5.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@rollup/rollup-linux-arm64-gnu": "^4.60.1",
    "@testing-library/react": "^16.0.0",
    "@types/katex": "^0.16.0",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.1",
    "class-variance-authority": "^0.7.1",
    "esbuild-sass-plugin": "^3.7.0",
    "esbuild": "^0.28.0",
    "jsdom": "^29.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sass": "^1.99.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vite": "^8.0.7",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "markdown",
    "streaming",
    "react",
    "ai",
    "chat",
    "mermaid",
    "katex",
    "latex",
    "math",
    "code-highlighting",
    "react-markdown",
    "remark",
    "rehype",
    "plugin-system"
  ],
  "author": "",
  "license": "MIT"
}
